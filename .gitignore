# =============================================================================
# .gitignore — Never commit these to GitHub!
# =============================================================================

# Secrets & cookies (NEVER push to git)
.env
cookies.txt
cookies_env.txt

# Downloaded media files
downloads/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Temp files
*.tmp
*.log
