# =============================================================================
# .env.example — Environment variables for the Telegram YouTube Downloader Bot
#
# HOW TO USE LOCALLY:
#   Copy this file to .env and fill in your values.
#   Then run:  pip install python-dotenv
#   And add at the top of app.py:
#       from dotenv import load_dotenv; load_dotenv()
#
# ON RENDER.COM:
#   Set these in: Dashboard → Your Service → Environment → Add Environment Variable
#   Do NOT commit your .env file to git!
# =============================================================================

# ------------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------------

# Your Telegram Bot Token from @BotFather
# Example: 1234567890:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here


# ------------------------------------------------------------------
# OPTIONAL (Render sets SERVER_URL automatically)
# ------------------------------------------------------------------

# Public URL of this server — used in status messages sent to Telegram.
# Render auto-sets this; only needed for local development.
# SERVER_URL=http://localhost:8000

# Folder where downloaded files are temporarily stored.
# DOWNLOADS_DIR=./downloads

# How long to keep files on disk (hours). Use 2 on Render (ephemeral FS).
# FILE_RETENTION_HOURS=2

# How often to run the disk cleanup (hours).
# CLEANUP_INTERVAL_HOURS=1

# ------------------------------------------------------------------
# OPTIONAL — YouTube Authentication Cookies
# ------------------------------------------------------------------
# Only needed for age-restricted or sign-in-required videos.
# Paste the full contents of your cookies.txt (Netscape format) here.
# Get it by: running the Chrome extension locally and copying cookies.txt
#
# YOUTUBE_COOKIES=# Netscape HTTP Cookie File
# .youtube.com	TRUE	/	TRUE	...
